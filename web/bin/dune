; The game ([main]) and its whole-maze debug view ([map_view]) are two js
; entry points onto the same {!Sandbox_web.App}.

(executables
 (names main map_view)
 (modes js)
 (js_of_ocaml
  (flags
   (:standard --effects=cps)))
 (libraries core bonsai_web sandbox_web)
 (preprocess
  (pps ppx_jane js_of_ocaml-ppx)))

; Keep the host pages and the audio next to the compiled bundles so
; _build/default/web/bin/index.html (and map_view.html) can be opened
; directly.

(copy_files
 (files ../../assets/*.mp3))

(rule
 (alias default)
 (deps
  main.bc.js
  index.html
  map_view.bc.js
  map_view.html
  (glob_files *.mp3))
 (action (progn)))
